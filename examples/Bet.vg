// Betting game: Gambler bets on race outcome
// Distribution semantics: Gambler stakes 10; wins 10 back on correct guess, otherwise the stake is burned.

type options = {1, 2, 3}

game main() {
  join Gambler(bet: options) $ 10;
  sample (winner: options);
  withdraw (Sample.winner == Gambler.bet)
      ? { Gambler -> 10 }
      : { Gambler -> 0; burn 10 }
}
